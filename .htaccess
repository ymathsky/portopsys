# Port Queuing Management System — Apache Configuration

# Disable directory listing
Options -Indexes

# Strip /qs prefix — rewrites portopsys.com/qs/anything → portopsys.com/anything
# This allows internal app links using /qs/ to work correctly
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^/qs/(.*)$
    RewriteRule ^qs/(.*)$ /$1 [L,R=301]
</IfModule>

# Follow symbolic links
Options +FollowSymLinks

# Default character set
AddDefaultCharset UTF-8

# PHP upload limits (applies when using mod_php; harmless on PHP-FPM)
<IfModule mod_php7.c>
    php_value upload_max_filesize 256M
    php_value post_max_size 260M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 256M
    php_value post_max_size 260M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Protect sensitive config files from direct web access
<FilesMatch "^(env|database|config)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent direct access to SQL files
<FilesMatch "\.sql$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
